{
  "manifest_version": 3,
  "name": "SiteSkin",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "description": "Modern reskins for unmaintained websites, delivered as remotely-updatable packs.",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["userScripts", "storage", "alarms", "tabs"],
  "host_permissions": [
    "*://zispa.org.zw/*",
    "*://www.zispa.org.zw/*",
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "SiteSkin",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  }
}
